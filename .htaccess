# NOTE: Canonical homepage URL rules and index handling.
RewriteEngine On

# NOTE: One hop for legacy http://www → canonical https://formaa.no (Search Console / duplicate host cleanup).
RewriteCond %{HTTP_HOST} ^www\.formaa\.no$ [NC]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://formaa.no%{REQUEST_URI} [L,R=301]

# NOTE: Force HTTPS for all requests before other canonical rules.
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# NOTE: Canonical host is apex formaa.no (strip www on HTTPS after scheme is correct).
RewriteCond %{HTTP_HOST} ^www\.formaa\.no$ [NC]
RewriteRule ^ https://formaa.no%{REQUEST_URI} [L,R=301]

# NOTE: Send HSTS header on HTTPS responses to enforce secure transport.
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

DirectoryIndex index.html

# NOTE: Custom 404 with root-absolute assets (see 404.html).
ErrorDocument 404 /404.html

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# NOTE: LLM/AI discovery files (plain text; also referenced in robots.txt).
# /llms.txt — full site scope and policies. /ai.txt — short companion for AI crawlers.
RewriteRule ^llms\.txt$ - [L]
RewriteRule ^ai\.txt$ - [L]

# NOTE: Canonical friendly routes for primary sections (keep ?project= detail URLs on advanced-project).
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^advanced-project/?$ /prosjekter [R=301,L]
RewriteRule ^blogg\.html$ /blogg [R=301,L]
RewriteRule ^application-form\.html$ /application-form [R=301,L]
RewriteRule ^arrangement\.html$ /arrangement [R=301,L]

# NOTE: Redirect legacy favicon asset requests to the current square full-bleed favicon.
RewriteRule ^assets/favicon\.svg$ /assets/square-favicon.svg [R=301,L]
RewriteRule ^assets/Favicon-google-search\.svg$ /assets/square-favicon.svg [R=301,L]

# NOTE: Dev article shell is not a public page; send crawlers to Blogg hub.
RewriteRule ^article-template/?$ /blogg [R=301,L]

# NOTE: Idegalleri page retired; send old /gallery URLs to homepage (extensionless and .html).
RewriteRule ^gallery\.html$ / [R=301,L]
RewriteRule ^gallery/?$ / [R=301,L]

# NOTE: Designstudio Oslo page retired; send old /designstudio-oslo URLs to homepage (extensionless and .html).
RewriteRule ^designstudio-oslo\.html$ / [R=301,L]
RewriteRule ^designstudio-oslo/?$ / [R=301,L]

# NOTE: Legacy Innsikt URLs → Blogg (301 for Search Console and bookmarks).
RewriteRule ^innsikt/?$ /blogg [R=301,L]
RewriteRule ^innsikt/([a-z0-9-]+)/?$ /blogg/$1 [R=301,L]
RewriteRule ^innsikt\.html$ /blogg [R=301,L]
RewriteRule ^innsikt-([a-z0-9-]+)/?$ /blogg/$1 [R=301,L]
RewriteRule ^innsikt-([a-z0-9-]+)\.html$ /blogg/$1 [R=301,L]
RewriteRule ^innsikt/innsikt-([a-z0-9-]+)/?$ /blogg/$1 [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/innsikt\.html$ /blogg [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/innsikt/?$ /blogg [R=301,L]

# NOTE: Move legacy flat article/project slugs into section-based URLs.
# New Blogg stubs (blogg-{slug}.html) auto-map to /blogg/{slug} — no per-article rules needed.
RewriteRule ^prosjekt-([a-z0-9-]+)/?$ /prosjekter/$1 [R=301,L]
RewriteRule ^blogg-([a-z0-9-]+)/?$ /blogg/$1 [R=301,L]

# NOTE: Legacy `.html` flat URLs (e.g. Search Console) → same canonical `/prosjekter/{slug}` and `/blogg/{slug}` before generic `.html` strip.
RewriteRule ^prosjekt-([a-z0-9-]+)\.html$ /prosjekter/$1 [R=301,L]
RewriteRule ^blogg-([a-z0-9-]+)\.html$ /blogg/$1 [R=301,L]

# NOTE: Heal legacy 404s from Search Console: duplicate Blogg paths, bad /category/…
# relatives, renamed produksjon → teknisk-tegning, and non-existent “index” hubs.
RewriteRule ^blogg/blogg-([a-z0-9-]+)/?$ /blogg/$1 [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/category/(.*)$ /category/$2 [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/index\.html$ /category/$1/norge [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/index/?$ /category/$1/norge [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/blogg\.html$ /blogg [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/blogg/?$ /blogg [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/oss\.html$ /oss [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/oss/?$ /oss [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/prisestimat\.html$ /prisestimat [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/prisestimat/?$ /prisestimat [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/advanced-project\.html$ /prosjekter [R=301,L]
RewriteRule ^category/([a-z0-9-]+)/advanced-project/?$ /prosjekter [R=301,L]
RewriteRule ^category/produksjon/?$ /category/teknisk-tegning/norge [R=301,L]
RewriteRule ^category/produksjon/(.*)$ /category/teknisk-tegning/$1 [R=301,L]

# NOTE: Remove `.html` from all public URLs.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# NOTE: Always serve project template for /prosjekter URLs (even when prosjekter/{slug}/ exists for static hosts).
RewriteRule ^prosjekter/([a-z0-9-]+)/?$ /advanced-project.html?seoSlug=$1 [L,QSA]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# NOTE: Serve Blogg articles from root stubs blogg-{slug}.html (see scripts/generate-blogg-indexes.mjs).
RewriteRule ^blogg/([a-z0-9-]+)/?$ /blogg-$1.html [L]
RewriteRule ^prosjekter/?$ /advanced-project.html [L]
RewriteRule ^blogg/?$ /blogg.html [L]

# NOTE: Internally map extensionless URLs to existing `.html` files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ /$1.html [L]
